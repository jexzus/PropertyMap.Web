    {
      "id": "plans_phase6_ranking_formula",
      "label": "Agent Ranking Formula",
      "type": "concept",
      "file_type": "concept",
      "source_file": "plans/2026-06-23-phase6-reputacion.md",
      "attributes": {
        "formula": "RankingScore = 0.40*ratingScore + 0.30*responseScore + 0.20*operacionesScore + 0.10*antiguedadScore",
        "weights": {
          "rating": 0.40,
          "response_time": 0.30,
          "operations": 0.20,
          "seniority": 0.10
        },
        "response_time_cap_hours": 72,
        "operations_cap": 50,
        "seniority_cap_years": 5,
        "rationale": "Weighted formula balances quality of service (rating) with responsiveness, activity, and trust signals; on-the-fly calculation avoids denormalization"
      }
    },
    {
      "id": "specs_phase6_no_new_migration",
      "label": "No New Migration for Phase 6",
      "type": "concept",
      "file_type": "rationale",
      "source_file": "specs/2026-06-23-phase6-reputacion-design.md",
      "attributes": {
        "description": "PropertyRating and AgentRating entities already exist in DB with constraints — no migration needed",
        "rationale": "Entities were pre-defined in Phase 3 domain model to avoid future migration complexity"
      }
    },
    {
      "id": "specs_phase6_upsert_pattern",
      "label": "Upsert Rating Pattern",
      "type": "concept",
      "file_type": "rationale",
      "source_file": "specs/2026-06-23-phase6-reputacion-design.md",
      "attributes": {
        "description": "AddOrUpdateAsync: update existing rating if found, insert new otherwise; unique index enforces one rating per user-entity",
        "rationale": "Users can refine their opinion after more experience; upsert removes need for separate update endpoint"
      }
    },
    {
      "id": "specs_phase6_alquiler_temporario_restriction",
      "label": "AlquilerTemporario Rating Restriction",
      "type": "concept",
      "file_type": "rationale",
      "source_file": "specs/2026-06-23-phase6-reputacion-design.md",
      "attributes": {
        "description": "Only AlquilerTemporario properties can be rated; validated in controller via IListingRepository",
        "rationale": "Temporary rentals have repeated tenancy creating natural rating context; other property types are one-time transactions"
      }
    },
    {
      "id": "specs_phase6_ranking_on_the_fly",
      "label": "On-the-Fly Ranking Calculation",
      "type": "concept",
      "file_type": "rationale",
      "source_file": "specs/2026-06-23-phase6-reputacion-design.md",
      "attributes": {
        "description": "RankingScore calculated in SQL query on each request; no denormalized RankingScore field in Publisher",
        "rationale": "Avoids stale data and migration; acceptable performance for initial scale; can add caching later if needed"
      }
    },
