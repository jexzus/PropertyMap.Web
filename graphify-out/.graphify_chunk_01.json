    {
      "id": "specs_phase5c_one_thread_per_pair",
      "label": "One Thread Per User-Property",
      "type": "concept",
      "file_type": "rationale",
      "source_file": "specs/2026-06-22-phase5c-consultas-design.md",
      "attributes": {
        "description": "GetOrCreateAsync + unique DB index ensures a single thread per (user, property) pair",
        "rationale": "Prevents fragmentation of conversation context; all messages about a property are in one place"
      }
    },
    {
      "id": "specs_phase5c_access_control",
      "label": "Consulta Access Control",
      "type": "concept",
      "file_type": "rationale",
      "source_file": "specs/2026-06-22-phase5c-consultas-design.md",
      "attributes": {
        "description": "Only thread owner and property publisher can view or write to a thread",
        "publisher_identity": "Resolved via Publisher.UserId == currentUserId",
        "rationale": "Privacy requirement — third parties cannot read private negotiations"
      }
    },
