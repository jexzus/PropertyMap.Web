    {
      "id": "specs_phase3_separate_api_project",
      "label": "Separate REST API Project",
      "type": "concept",
      "file_type": "rationale",
      "source_file": "specs/2026-06-19-propertymap-phase3plus-design.md",
      "attributes": {
        "description": "PropertyMap.Api is a dedicated ASP.NET Core REST API separate from the Blazor project",
        "rationale": "Enables independent scaling, mobile client support, and clean separation between SSR rendering concerns and API concerns"
      }
    },
    {
      "id": "specs_phase3_jwt_auth",
      "label": "JWT Authentication",
      "type": "concept",
      "file_type": "concept",
      "source_file": "specs/2026-06-19-propertymap-phase3plus-design.md",
      "attributes": {
        "access_token_ttl": "15 minutes",
        "refresh_token_ttl": "7 days",
        "refresh_token_rotation": true,
        "storage": "ProtectedLocalStorage",
        "rationale": "Short-lived access tokens minimize exposure; rotating refresh tokens prevent token theft reuse"
      }
    },
    {
      "id": "specs_phase3_blazor_auth_provider",
