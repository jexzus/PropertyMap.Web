      "attributes": {
        "description": "Custom AuthenticationStateProvider for Blazor SSR, reads from MemoryTokenStore",
        "memory_token_store": "Scoped per circuit, holds access token in memory between renders"
      }
    },
    {
      "id": "specs_phase3_phase_roadmap",
      "label": "Phase Roadmap 3-9",
      "type": "concept",
      "file_type": "document",
      "source_file": "specs/2026-06-19-propertymap-phase3plus-design.md",
      "attributes": {
        "phases": {
          "3": "Foundation API (JWT, base entities)",
          "4": "Publisher CRUD (listings, images)",
          "5a": "User Features (profile, avatars)",
          "5b": "Favorites + View Tracking",
          "5c": "Consultas (private messaging threads)",
          "6": "Reputación (ratings + agent ranking)",
          "7": "Inteligencia (AI features)",
          "8": "Monetización (plans, subscriptions)",
          "9": "Escala (caching, CDN, performance)"
        }
      }
    },
