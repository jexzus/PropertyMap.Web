@inject IRatingsApiService RatingsService
@using PropertyMap.Core.DTOs.Ratings
@using PropertyMap.Web.Services

<div class="rating-form">
    <h4>Valorar al agente</h4>

    @if (_success)
    {
        <p class="text-success">¡Gracias por tu valoración!</p>
        @if (Stats is not null)
        {
            <div class="rating-stats mt-2">
                <small class="text-muted">Promedios actualizados:</small>
                <div class="d-flex flex-column gap-1 mt-1">
                    <div class="d-flex align-items-center gap-2">
                        <span class="text-muted" style="min-width:150px">Atención</span>
                        <RatingStars Value="Stats.PromedioAtencion" ReadOnly="true" />
                        <small class="text-muted">(@Stats.PromedioAtencion.ToString("F1"))</small>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="text-muted" style="min-width:150px">Rapidez</span>
                        <RatingStars Value="Stats.PromedioRapidez" ReadOnly="true" />
                        <small class="text-muted">(@Stats.PromedioRapidez.ToString("F1"))</small>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="text-muted" style="min-width:150px">Transparencia</span>
                        <RatingStars Value="Stats.PromedioTransparencia" ReadOnly="true" />
                        <small class="text-muted">(@Stats.PromedioTransparencia.ToString("F1"))</small>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="text-muted" style="min-width:150px">Profesionalismo</span>
                        <RatingStars Value="Stats.PromedioProfesionalismo" ReadOnly="true" />
                        <small class="text-muted">(@Stats.PromedioProfesionalismo.ToString("F1"))</small>
                    </div>
                </div>
                <div class="mt-1">
                    <small class="text-muted">@Stats.TotalValoraciones valoración(es) en total</small>
                </div>
            </div>
        }
    }
    else
    {
        <div class="rating-criterion">
            <label>Atención</label>
            <RatingStars Value="_atencion" ReadOnly="false" OnChange="v => _atencion = v" />
        </div>
        <div class="rating-criterion">
            <label>Rapidez</label>
            <RatingStars Value="_rapidez" ReadOnly="false" OnChange="v => _rapidez = v" />
        </div>
        <div class="rating-criterion">
            <label>Transparencia</label>
            <RatingStars Value="_transparencia" ReadOnly="false" OnChange="v => _transparencia = v" />
        </div>
        <div class="rating-criterion">
            <label>Profesionalismo</label>
            <RatingStars Value="_profesionalismo" ReadOnly="false" OnChange="v => _profesionalismo = v" />
        </div>
        <textarea @bind="_comentario" placeholder="Comentario opcional..." rows="3" class="form-control mt-2"></textarea>

        @if (_error is not null)
        {
            <p class="text-danger mt-2">@_error</p>
        }

        <button class="btn btn-primary mt-2" @onclick="Submit" disabled="@(!CanSubmit)">Valorar</button>
    }
</div>

@code {
    [Parameter] public int PublisherId { get; set; }
    [Parameter] public AgentRatingStatsDto? Stats { get; set; }

    private int _atencion, _rapidez, _transparencia, _profesionalismo;
    private string? _comentario, _error;
    private bool _success;

    private bool CanSubmit => _atencion > 0 && _rapidez > 0 && _transparencia > 0 && _profesionalismo > 0;

    private async Task Submit()
    {
        _error = null;
        var result = await RatingsService.RateAgentAsync(new RateAgentRequest(
            PublisherId, _atencion, _rapidez, _transparencia, _profesionalismo, _comentario));
        if (result is null)
            _error = "No se pudo guardar la valoración. Verificá que tengas una consulta activa.";
        else
        {
            _success = true;
            Stats = result;
        }
    }
}
