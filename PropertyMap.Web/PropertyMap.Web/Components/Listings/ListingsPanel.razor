@using PropertyMap.Core.Entities

<div class="listings-panel-wrapper @(IsCollapsed ? "collapsed" : "")" id="listings-panel">
    @if (!IsCollapsed)
    {
        <div class="panel-header">
            <span class="panel-count">
                @if (IsLoading)
                {
                    <span>Buscando...</span>
                }
                else
                {
                    <strong>@Listings.Count</strong>
                    @(Listings.Count == 1 ? " propiedad" : " propiedades")
                }
            </span>
            <button class="btn-icon" @onclick="OnToggleCollapse" title="Colapsar panel" aria-label="Colapsar panel de listados">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <polyline points="15 18 9 12 15 6"/>
                </svg>
            </button>
        </div>

        <div class="panel-scroll" id="panel-scroll">
            @if (IsLoading)
            {
                @for (int i = 0; i < 4; i++)
                {
                    <div class="property-card" style="pointer-events:none">
                        <div class="skeleton" style="height:160px;border-radius:0"></div>
                        <div class="card-body" style="display:flex;flex-direction:column;gap:8px">
                            <div class="skeleton" style="height:24px;width:60%;border-radius:4px"></div>
                            <div class="skeleton" style="height:16px;width:40%;border-radius:4px"></div>
                            <div class="skeleton" style="height:14px;width:80%;border-radius:4px"></div>
                        </div>
                    </div>
                }
            }
            else if (!Listings.Any())
            {
                <div class="panel-empty">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                        <line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/>
                    </svg>
                    <p>No hay propiedades en esta zona con los filtros aplicados.</p>
                    <p style="font-size:var(--text-xs)">Probá ajustando los filtros o mové el mapa.</p>
                </div>
            }
            else
            {
                @foreach (var listing in Listings)
                {
                    <PropertyCard
                        Listing="listing"
                        IsSelected="@(SelectedListingId == listing.Id)"
                        OnSelect="OnListingSelected" />
                }
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public List<PropertyListing> Listings { get; set; } = [];
    [Parameter] public int? SelectedListingId { get; set; }
    [Parameter] public bool IsCollapsed { get; set; }
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public EventCallback<int> OnListingSelected { get; set; }
    [Parameter] public EventCallback OnToggleCollapse { get; set; }
}
