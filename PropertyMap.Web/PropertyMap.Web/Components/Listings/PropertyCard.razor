@using PropertyMap.Core.Entities
@using PropertyMap.Core.Enums
@using System.Linq
@inject IJSRuntime JS

<div class="property-card @(IsSelected ? "selected" : "") @(IsHighlighted ? "highlighted" : "")"
     @onclick="HandleClick"
     @onmouseenter="HandleMouseEnter"
     @onmouseleave="HandleMouseLeave"
     role="button" tabindex="0"
     @onkeydown="HandleKeyDown"
     aria-label="@Listing.Titulo">

    @* ── Carousel ── *@
    <div class="card-carousel" @onclick:stopPropagation="false">
        <div class="carousel-track" style="transform: translateX(-@(currentPhoto * 100)%)">
            @if (Listing.Images.Any())
            {
                @foreach (var image in Listing.Images.OrderBy(img => img.Orden))
                {
                    <img class="carousel-photo" src="@image.Url" alt="@Listing.Titulo" loading="lazy" />
                }
            }
            else
            {
                <div class="card-photo-placeholder">
                    <svg width="36" height="36" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
                    </svg>
                </div>
            }
        </div>

        @if (Listing.Images.Count > 1)
        {
            <button class="carousel-btn carousel-btn--prev" @onclick="PrevPhoto" @onclick:stopPropagation="true" aria-label="Foto anterior">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <button class="carousel-btn carousel-btn--next" @onclick="NextPhoto" @onclick:stopPropagation="true" aria-label="Foto siguiente">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
            <div class="carousel-dots">
                @for (int i = 0; i < Math.Min(Listing.Images.Count, 5); i++)
                {
                    var idx = i;
                    <span class="carousel-dot @(currentPhoto == idx ? "active" : "")" @onclick="() => GoToPhoto(idx)" @onclick:stopPropagation="true"></span>
                }
            </div>
        }

        <span class="card-badge-operacion badge-@Listing.Operacion.ToString().ToLower()">@OperacionLabel</span>
    </div>

    @* ── Body ── *@
    <div class="card-body">
        <div class="card-price">@FormatPrice()</div>

        <div class="card-title">@Listing.Titulo</div>

        @if (Listing.Location is not null)
        {
            <div class="card-address">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
                </svg>
                @Listing.Location.DireccionTexto, @Listing.Location.Ciudad
            </div>
        }

        @if (HasStats)
        {
            <div class="card-stats">
                @if (Listing.Superficie.HasValue)
                {
                    <span class="card-stat">
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="1"/></svg>
                        @Listing.Superficie m²
                    </span>
                }
                @if (Listing.Dormitorios.HasValue)
                {
                    <span class="card-stat">
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M2 20v-8a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v8"/><path d="M4 10V6a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v4"/></svg>
                        @Listing.Dormitorios dorm.
                    </span>
                }
                @if (Listing.Banos.HasValue)
                {
                    <span class="card-stat">
                        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 6 6.5 3.5a1.5 1.5 0 0 0-1-.5C4.683 3 4 3.683 4 4.5V17a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-5"/><line x1="10" y1="5" x2="8" y2="7"/></svg>
                        @Listing.Banos ba.
                    </span>
                }
                @if (Listing.Ambientes.HasValue && !Listing.Dormitorios.HasValue)
                {
                    <span class="card-stat">@Listing.Ambientes amb.</span>
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public PropertyListing Listing { get; set; } = null!;
    [Parameter] public bool IsSelected { get; set; }
    [Parameter] public bool IsHighlighted { get; set; }
    [Parameter] public EventCallback<int> OnSelect { get; set; }
    [Parameter] public EventCallback<int?> OnHover { get; set; }

    private int currentPhoto;

    private string OperacionLabel => Listing.Operacion switch
    {
        TipoOperacion.Venta              => "Venta",
        TipoOperacion.Alquiler           => "Alquiler",
        TipoOperacion.AlquilerTemporario => "Temporario",
        _                                => Listing.Operacion.ToString()
    };

    private bool HasStats =>
        Listing.Superficie.HasValue || Listing.Ambientes.HasValue ||
        Listing.Dormitorios.HasValue || Listing.Banos.HasValue;

    private string FormatPrice()
    {
        var sym = Listing.Moneda == "USD" ? "U$S" : "$";
        return $"{sym} {Listing.Precio:N0}";
    }

    private void PrevPhoto() => currentPhoto = currentPhoto > 0 ? currentPhoto - 1 : Listing.Images.Count - 1;
    private void NextPhoto() => currentPhoto = currentPhoto < Listing.Images.Count - 1 ? currentPhoto + 1 : 0;
    private void GoToPhoto(int idx) => currentPhoto = idx;

    private async Task HandleClick()
    {
        await OnSelect.InvokeAsync(Listing.Id);
        await JS.InvokeVoidAsync("open", $"/property/{Listing.Id}", "_blank");
    }

    private async Task HandleMouseEnter() => await OnHover.InvokeAsync(Listing.Id);
    private async Task HandleMouseLeave() => await OnHover.InvokeAsync(null);

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or " ")
            await HandleClick();
    }
}
