@page "/Account/ForgotPassword"
@rendermode InteractiveServer
@inject IAuthService AuthService

<PageTitle>Recuperar contraseña — PropertyMap</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <a href="/" class="auth-logo">PropertyMap</a>
        <h1 class="auth-title">Recuperar contraseña</h1>

        @* Indicador de paso *@
        @if (paso < 3)
        {
            <div style="display:flex;gap:8px;margin-bottom:24px;align-items:center">
                <StepDot Number="1" Active="@(paso >= 1)" />
                <div style="flex:1;height:2px;background:@(paso >= 2 ? "var(--color-primary)" : "var(--color-border)")"></div>
                <StepDot Number="2" Active="@(paso >= 2)" />
            </div>
        }

        @if (error is not null)
        {
            <div class="auth-error">@error</div>
        }

        @* PASO 1: Email *@
        @if (paso == 1)
        {
            <p style="color:var(--color-muted);font-size:var(--text-sm);margin-bottom:16px">
                Ingresá tu email y te enviaremos un código para restablecer tu contraseña.
            </p>
            <div class="field">
                <label class="field-label" for="email">Email</label>
                <input id="email" type="email" class="field-input"
                       @bind="email" placeholder="tu@email.com" autocomplete="email" />
            </div>
            <button class="btn-primary auth-btn" @onclick="SolicitarCodigo" disabled="@loading">
                @(loading ? "Enviando..." : "Enviar código")
            </button>
        }

        @* PASO 2: Código + nueva contraseña *@
        @if (paso == 2)
        {
            <p style="color:var(--color-muted);font-size:var(--text-sm);margin-bottom:16px">
                Ingresá el código de 6 dígitos enviado a <strong>@email</strong> y tu nueva contraseña.
            </p>
            <div class="field">
                <label class="field-label" for="codigo">Código</label>
                <input id="codigo" type="text" class="field-input"
                       @bind="codigo" placeholder="123456"
                       maxlength="6" inputmode="numeric" autocomplete="one-time-code"
                       style="font-size:24px;letter-spacing:8px;text-align:center" />
            </div>
            <div class="field">
                <label class="field-label" for="password">Nueva contraseña</label>
                <input id="password" type="password" class="field-input"
                       @bind="password" placeholder="Mín. 8 caracteres, 1 mayúscula, 1 número, 1 símbolo"
                       autocomplete="new-password" />
            </div>
            <div class="field">
                <label class="field-label" for="confirm">Confirmar contraseña</label>
                <input id="confirm" type="password" class="field-input"
                       @bind="confirm" placeholder="Repetí la contraseña"
                       autocomplete="new-password" />
            </div>
            <button class="btn-primary auth-btn" @onclick="CambiarContrasena" disabled="@loading">
                @(loading ? "Guardando..." : "Restablecer contraseña")
            </button>
            <p class="auth-footer">
                ¿No llegó el código? <button class="link-btn" @onclick="SolicitarCodigo" disabled="@loading">Reenviar</button>
            </p>
        }

        @* ÉXITO *@
        @if (paso == 3)
        {
            <div class="auth-success">
                ✓ Contraseña actualizada correctamente. Ya podés iniciar sesión.
            </div>
            <a href="/Account/Login" class="btn-primary auth-btn" style="text-align:center;display:block">
                Ir al login
            </a>
        }

        @if (paso < 3)
        {
            <p class="auth-footer">
                <a href="/Account/Login">Volver al login</a>
            </p>
        }
    </div>
</div>

@code {
    private int paso = 1;
    private string email = "";
    private string codigo = "";
    private string password = "";
    private string confirm = "";
    private string? error;
    private bool loading;

    private async Task SolicitarCodigo()
    {
        if (string.IsNullOrWhiteSpace(email)) { error = "Ingresá tu email."; return; }
        loading = true; error = null;
        var (ok, err) = await AuthService.SolicitarRecuperacionAsync(email.Trim());
        loading = false;
        if (ok) paso = 2;
        else error = err;
    }

    private async Task CambiarContrasena()
    {
        if (string.IsNullOrWhiteSpace(codigo)) { error = "Ingresá el código."; return; }
        if (string.IsNullOrWhiteSpace(password)) { error = "Ingresá la nueva contraseña."; return; }
        if (password != confirm) { error = "Las contraseñas no coinciden."; return; }

        loading = true; error = null;
        var (ok, err) = await AuthService.CambiarContrasenaAsync(email.Trim(), codigo.Trim(), password);
        loading = false;
        if (ok) paso = 3;
        else error = err;
    }
}
