@page "/Account/ForgotPassword"
@rendermode InteractiveServer
@inject IAuthService AuthService

<PageTitle>Recuperar contraseña — PropertyMap</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <a href="/" class="auth-logo">PropertyMap</a>
        <h1 class="auth-title">Recuperar contraseña</h1>

        @if (error is not null)
        {
            <div class="auth-error">@error</div>
        }

        @if (sent)
        {
            <div class="auth-success">
                ✓ Si el email existe, recibirás un link para restablecer tu contraseña en breve.
            </div>
            <a href="/Account/Login" class="btn-primary auth-btn" style="text-align:center;display:block">
                Volver al login
            </a>
        }
        else
        {
            <p style="color:var(--color-muted);font-size:var(--text-sm);margin-bottom:var(--space-4)">
                Ingresá tu email y te enviaremos un link para restablecer tu contraseña.
            </p>

            <div class="field">
                <label class="field-label" for="email">Email</label>
                <input id="email" type="email" class="field-input"
                       @bind="email" placeholder="tu@email.com" autocomplete="email" />
            </div>

            <button class="btn-primary auth-btn" @onclick="DoSend" disabled="@loading">
                @(loading ? "Enviando..." : "Enviar link de recuperación")
            </button>

            <p class="auth-footer">
                <a href="/Account/Login">Volver al login</a>
            </p>
        }
    </div>
</div>

@code {
    private string email = "";
    private string? error;
    private bool loading;
    private bool sent;

    private async Task DoSend()
    {
        if (string.IsNullOrWhiteSpace(email))
        {
            error = "Ingresá tu email.";
            return;
        }
        loading = true;
        error = null;
        var (ok, err) = await AuthService.ForgotPasswordAsync(email.Trim());
        loading = false;
        if (ok) sent = true;
        else error = err;
    }
}
