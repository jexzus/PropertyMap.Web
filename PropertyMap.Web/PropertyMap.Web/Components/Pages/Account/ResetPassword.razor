@page "/reset-password"
@rendermode InteractiveServer
@inject IAuthService AuthService
@inject NavigationManager Nav

<PageTitle>Nueva contraseña — PropertyMap</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <a href="/" class="auth-logo">PropertyMap</a>
        <h1 class="auth-title">Nueva contraseña</h1>

        @if (error is not null)
        {
            <div class="auth-error">@error</div>
        }

        @if (success)
        {
            <div class="auth-success">
                ✓ Contraseña restablecida correctamente. Ya podés iniciar sesión.
            </div>
            <a href="/Account/Login" class="btn-primary auth-btn" style="text-align:center;display:block">
                Ir al login
            </a>
        }
        else if (Token is null || Email is null)
        {
            <div class="auth-error">Link inválido. Solicitá un nuevo link de recuperación.</div>
            <a href="/Account/ForgotPassword" class="btn-primary auth-btn" style="text-align:center;display:block">
                Solicitar nuevo link
            </a>
        }
        else
        {
            <div class="field">
                <label class="field-label" for="password">Nueva contraseña</label>
                <input id="password" type="password" class="field-input"
                       @bind="password" placeholder="Mín. 8 caracteres, 1 mayúscula, 1 número, 1 símbolo"
                       autocomplete="new-password" />
            </div>

            <div class="field">
                <label class="field-label" for="confirm">Confirmar contraseña</label>
                <input id="confirm" type="password" class="field-input"
                       @bind="confirm" placeholder="Repetí la contraseña"
                       autocomplete="new-password" />
            </div>

            <button class="btn-primary auth-btn" @onclick="DoReset" disabled="@loading">
                @(loading ? "Guardando..." : "Restablecer contraseña")
            </button>
        }
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    private string? Token { get; set; }

    [SupplyParameterFromQuery]
    private string? Email { get; set; }

    private string password = "";
    private string confirm = "";
    private string? error;
    private bool loading;
    private bool success;

    private async Task DoReset()
    {
        if (string.IsNullOrWhiteSpace(password) || string.IsNullOrWhiteSpace(confirm))
        {
            error = "Completá ambos campos.";
            return;
        }
        if (password != confirm)
        {
            error = "Las contraseñas no coinciden.";
            return;
        }
        loading = true;
        error = null;
        var (ok, err) = await AuthService.ResetPasswordAsync(Email!, Token!, password, confirm);
        loading = false;
        if (ok) success = true;
        else error = err;
    }
}
