@page "/top-agentes"
@rendermode InteractiveServer

@using PropertyMap.Core.DTOs.Ratings
@inject IRatingsApiService RatingsService

<PageTitle>Top Agentes — PropertyMap</PageTitle>

<h1>Top Agentes</h1>

<div style="display:flex;gap:var(--space-2);margin-bottom:var(--space-4)">
    <input type="text" @bind="_ciudad" @bind:event="oninput" placeholder="Filtrar por ciudad..."
           style="padding:var(--space-2) var(--space-3);border:1px solid var(--color-border);border-radius:var(--radius-sm);max-width:250px;font-family:var(--font-sans);font-size:var(--text-sm);color:var(--color-ink);background:var(--color-bg);outline:none" />
    <button class="btn-ghost" @onclick="LoadRanking">Filtrar</button>
</div>

@if (_loading)
{
    <p>Cargando...</p>
}
else if (_ranking.Count == 0)
{
    <p style="color:var(--color-muted)">No hay agentes rankeados todavía.</p>
}
else
{
    <table style="width:100%;border-collapse:collapse">
        <thead>
            <tr>
                <th style="border-bottom:1px solid var(--color-border);padding:var(--space-2) var(--space-3);text-align:left">#</th>
                <th style="border-bottom:1px solid var(--color-border);padding:var(--space-2) var(--space-3);text-align:left">Nombre</th>
                <th style="border-bottom:1px solid var(--color-border);padding:var(--space-2) var(--space-3);text-align:left">Tipo</th>
                <th style="border-bottom:1px solid var(--color-border);padding:var(--space-2) var(--space-3);text-align:left">Score</th>
                <th style="border-bottom:1px solid var(--color-border);padding:var(--space-2) var(--space-3);text-align:left">Rating</th>
                <th style="border-bottom:1px solid var(--color-border);padding:var(--space-2) var(--space-3);text-align:left">T. Respuesta</th>
                <th style="border-bottom:1px solid var(--color-border);padding:var(--space-2) var(--space-3);text-align:left">Operaciones</th>
                <th style="border-bottom:1px solid var(--color-border);padding:var(--space-2) var(--space-3);text-align:left">Antigüedad</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < _ranking.Count; i++)
            {
                var agent = _ranking[i];
                var pos = i + 1;
                <tr>
                    <td style="border-bottom:1px solid var(--color-border);padding:var(--space-2) var(--space-3)">@pos</td>
                    <td style="border-bottom:1px solid var(--color-border);padding:var(--space-2) var(--space-3)">@agent.Nombre</td>
                    <td style="border-bottom:1px solid var(--color-border);padding:var(--space-2) var(--space-3)">@agent.Tipo</td>
                    <td style="border-bottom:1px solid var(--color-border);padding:var(--space-2) var(--space-3)">@agent.RankingScore.ToString("F1")</td>
                    <td style="border-bottom:1px solid var(--color-border);padding:var(--space-2) var(--space-3)">@agent.RatingPromedio.ToString("F1") ★</td>
                    <td style="border-bottom:1px solid var(--color-border);padding:var(--space-2) var(--space-3)">@agent.TiempoRespuestaHoras.ToString("F0")h</td>
                    <td style="border-bottom:1px solid var(--color-border);padding:var(--space-2) var(--space-3)">@agent.Operaciones</td>
                    <td style="border-bottom:1px solid var(--color-border);padding:var(--space-2) var(--space-3)">@agent.AntiguedadAnios.ToString("F1") años</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<AgentRankingItemDto> _ranking = [];
    private string? _ciudad;
    private bool _loading = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadRanking();
            StateHasChanged();
        }
    }

    private async Task LoadRanking()
    {
        _loading = true;
        StateHasChanged();
        _ranking = await RatingsService.GetRankingAsync(
            string.IsNullOrWhiteSpace(_ciudad) ? null : _ciudad);
        _loading = false;
    }
}
