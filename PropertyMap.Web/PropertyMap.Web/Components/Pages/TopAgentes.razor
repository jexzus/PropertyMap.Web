@page "/top-agentes"
@rendermode InteractiveServer

@using PropertyMap.Core.DTOs.Ratings
@inject IRatingsApiService RatingsService

<PageTitle>Top Agentes — PropertyMap</PageTitle>

<h1>Top Agentes</h1>

<div class="mb-3 d-flex gap-2">
    <input type="text" @bind="_ciudad" @bind:event="oninput" placeholder="Filtrar por ciudad..." class="form-control" style="max-width:250px" />
    <button class="btn btn-outline-secondary" @onclick="LoadRanking">Filtrar</button>
</div>

@if (_loading)
{
    <p>Cargando...</p>
}
else if (_ranking.Count == 0)
{
    <p class="text-muted">No hay agentes rankeados todavía.</p>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                <th>#</th>
                <th>Nombre</th>
                <th>Tipo</th>
                <th>Score</th>
                <th>Rating</th>
                <th>T. Respuesta</th>
                <th>Operaciones</th>
                <th>Antigüedad</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < _ranking.Count; i++)
            {
                var agent = _ranking[i];
                var pos = i + 1;
                <tr>
                    <td>@pos</td>
                    <td>@agent.Nombre</td>
                    <td>@agent.Tipo</td>
                    <td>@agent.RankingScore.ToString("F1")</td>
                    <td>@agent.RatingPromedio.ToString("F1") ★</td>
                    <td>@agent.TiempoRespuestaHoras.ToString("F0")h</td>
                    <td>@agent.Operaciones</td>
                    <td>@agent.AntiguedadAnios.ToString("F1") años</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<AgentRankingItemDto> _ranking = [];
    private string? _ciudad;
    private bool _loading = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadRanking();
            StateHasChanged();
        }
    }

    private async Task LoadRanking()
    {
        _loading = true;
        StateHasChanged();
        _ranking = await RatingsService.GetRankingAsync(
            string.IsNullOrWhiteSpace(_ciudad) ? null : _ciudad);
        _loading = false;
    }
}
