@page "/property/{Id:int}"
@using PropertyMap.Core.DTOs
@using PropertyMap.Core.DTOs.Ratings
@using PropertyMap.Web.Components.Reports
@inject IListingApiService ListingApi
@inject NavigationManager Nav
@inject IRatingsApiService RatingsService
@rendermode InteractiveServer

<PageTitle>@(detail?.Titulo ?? "Propiedad") — PropertyMap</PageTitle>

@if (loading)
{
    <div class="detail-loading">
        <div class="detail-spinner"></div>
    </div>
}
else if (detail is null)
{
    <div class="detail-not-found">
        <h2>Propiedad no encontrada</h2>
        <a href="/" class="btn-primary">Volver al mapa</a>
    </div>
}
else
{
    <div class="detail-shell">

        @* ── Navbar mínimo ── *@
        <nav class="detail-nav">
            <a href="/" class="pm-navbar__logo">PropertyMap</a>
            <a href="/" class="btn-ghost detail-back">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
                Volver al mapa
            </a>
        </nav>

        <div class="detail-content">

            @* ── Galería ── *@
            <div class="detail-gallery">
                @if (detail.FotoUrls.Any())
                {
                    <div class="gallery-main">
                        <img src="@detail.FotoUrls[galleryIdx]" alt="@detail.Titulo" class="gallery-main-img" />
                        @if (detail.FotoUrls.Count > 1)
                        {
                            <button class="gallery-btn gallery-btn--prev" @onclick="PrevPhoto" aria-label="Anterior">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
                            </button>
                            <button class="gallery-btn gallery-btn--next" @onclick="NextPhoto" aria-label="Siguiente">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
                            </button>
                            <span class="gallery-counter">@(galleryIdx + 1) / @detail.FotoUrls.Count</span>
                        }
                    </div>

                    @if (detail.FotoUrls.Count > 1)
                    {
                        <div class="gallery-thumbs">
                            @foreach (var (url, idx) in detail.FotoUrls.Select((u, i) => (u, i)))
                            {
                                var capturedIdx = idx;
                                <img src="@url"
                                     class="gallery-thumb @(galleryIdx == capturedIdx ? "active" : "")"
                                     @onclick="() => galleryIdx = capturedIdx"
                                     alt="Foto @(capturedIdx+1)"
                                     loading="lazy" />
                            }
                        </div>
                    }
                }
            </div>

            @* ── Info ── *@
            <div class="detail-info">
                <div class="detail-header">
                    <div>
                        <span class="detail-badge badge-@detail.Operacion.ToLower()">@OperacionLabel</span>
                        <h1 class="detail-title">@detail.Titulo</h1>
                        <p class="detail-address">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
                            </svg>
                            @detail.DireccionTexto, @detail.Ciudad, @detail.Provincia
                        </p>
                    </div>
                    <div style="display:flex;flex-direction:column;align-items:flex-end;gap:var(--space-1)">
                        <div class="detail-price">@FormatPrice()</div>
                        @if (_ratingStats?.TotalValoraciones > 0)
                        {
                            <div style="display:flex;align-items:center;gap:var(--space-2);margin-top:var(--space-1)">
                                <RatingStars Value="_ratingStats.PromedioGeneral" ReadOnly="true" />
                                <span style="font-size:0.85rem;color:var(--color-muted)">@_ratingStats.PromedioGeneral.ToString("F1") (@_ratingStats.TotalValoraciones valoraciones)</span>
                            </div>
                        }
                        <FavoriteButton ListingId="@Id" />
                        <AuthorizeView>
                            <Authorized>
                                <a href="/account/consultas/nueva?listingId=@Id" class="btn-ghost"
                                   style="font-size:0.875rem">
                                    Consultar al publisher
                                </a>
                                <button class="btn-ghost" @onclick="() => _reportModalOpen = true">Reportar</button>
                                <ReportModal IsOpen="_reportModalOpen" PropertyListingId="@Id"
                                             OnClosed="@(() => _reportModalOpen = false)" />
                            </Authorized>
                        </AuthorizeView>
                    </div>
                </div>

                @* Stats ── *@
                @if (HasStats)
                {
                    <div class="detail-stats">
                        @if (detail.Superficie.HasValue)
                        {
                            <div class="detail-stat">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="1"/></svg>
                                <span class="stat-value">@detail.Superficie m²</span>
                                <span class="stat-label">Superficie</span>
                            </div>
                        }
                        @if (detail.Ambientes.HasValue)
                        {
                            <div class="detail-stat">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="1"/><path d="M3 9h18"/></svg>
                                <span class="stat-value">@detail.Ambientes</span>
                                <span class="stat-label">Ambientes</span>
                            </div>
                        }
                        @if (detail.Dormitorios.HasValue)
                        {
                            <div class="detail-stat">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 20v-8a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v8"/><path d="M4 10V6a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v4"/></svg>
                                <span class="stat-value">@detail.Dormitorios</span>
                                <span class="stat-label">Dormitorios</span>
                            </div>
                        }
                        @if (detail.Banos.HasValue)
                        {
                            <div class="detail-stat">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 6 6.5 3.5a1.5 1.5 0 0 0-1-.5C4.683 3 4 3.683 4 4.5V17a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-5"/><line x1="10" y1="5" x2="8" y2="7"/></svg>
                                <span class="stat-value">@detail.Banos</span>
                                <span class="stat-label">Baños</span>
                            </div>
                        }
                        @if (detail.SuperficieCubierta.HasValue)
                        {
                            <div class="detail-stat">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="1"/><path d="M3 9h18M9 3v18"/></svg>
                                <span class="stat-value">@detail.SuperficieCubierta m²</span>
                                <span class="stat-label">Cubierta</span>
                            </div>
                        }
                        @if (detail.Antiguedad.HasValue)
                        {
                            <div class="detail-stat">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
                                <span class="stat-value">@(detail.Antiguedad == 0 ? "A estrenar" : $"{detail.Antiguedad} años")</span>
                                <span class="stat-label">Antigüedad</span>
                            </div>
                        }
                        @if (detail.Cochera)
                        {
                            <div class="detail-stat">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5 17v-4l1.6-4.2A2 2 0 0 1 8.5 7.5h7a2 2 0 0 1 1.9 1.3L19 13v4"/><path d="M3 13h18"/><circle cx="7.5" cy="17" r="1.5"/><circle cx="16.5" cy="17" r="1.5"/></svg>
                                <span class="stat-value">Sí</span>
                                <span class="stat-label">Cochera</span>
                            </div>
                        }
                    </div>
                }

                @* Descripción ── *@
                @if (!string.IsNullOrWhiteSpace(detail.Descripcion))
                {
                    <div class="detail-section">
                        <h2 class="detail-section-title">Descripción</h2>
                        <p class="detail-description">@detail.Descripcion</p>
                    </div>
                }

                @* Comodidades ── *@
                @if (detail.Amenities.Count > 0)
                {
                    <div class="detail-section">
                        <h2 class="detail-section-title">Comodidades</h2>
                        <div class="amenities-grid">
                            @foreach (var a in detail.Amenities)
                            {
                                <div class="amenity-chip">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                                    @a
                                </div>
                            }
                        </div>
                    </div>
                }

                @* Ubicación ── *@
                <div class="detail-section">
                    <h2 class="detail-section-title">Ubicación</h2>
                    <div class="detail-map-wrap">
                        <LocationMap Lat="detail.Lat" Lng="detail.Lng" Height="320px" />
                    </div>
                </div>

                @* Publicador ── *@
                @if (!string.IsNullOrEmpty(detail.PublisherNombre))
                {
                    <div class="detail-section detail-publisher">
                        <h2 class="detail-section-title">Publicado por</h2>
                        <div class="publisher-card">
                            <div class="publisher-avatar">
                                @detail.PublisherNombre[0]
                            </div>
                            <div>
                                <div class="publisher-name">@detail.PublisherNombre</div>
                                @if (!string.IsNullOrEmpty(detail.PublisherTelefono))
                                {
                                    <a href="tel:@detail.PublisherTelefono" class="publisher-phone">@detail.PublisherTelefono</a>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private ListingDetailDto? detail;
    private bool loading = true;
    private int galleryIdx;
    private PropertyRatingStatsDto? _ratingStats;
    private bool _reportModalOpen;

    protected override async Task OnInitializedAsync()
    {
        detail = await ListingApi.GetByIdAsync(Id);
        if (detail is not null)
            _ratingStats = await RatingsService.GetPropertyStatsAsync(detail.Id);
        loading = false;
    }

    private void PrevPhoto() => galleryIdx = galleryIdx > 0 ? galleryIdx - 1 : (detail!.FotoUrls.Count - 1);
    private void NextPhoto() => galleryIdx = galleryIdx < detail!.FotoUrls.Count - 1 ? galleryIdx + 1 : 0;

    private string OperacionLabel => detail?.Operacion switch
    {
        "Venta"              => "Venta",
        "Alquiler"           => "Alquiler",
        "AlquilerTemporario" => "Alquiler Temporario",
        _                    => detail?.Operacion ?? ""
    };

    private bool HasStats => detail is not null &&
        (detail.Superficie.HasValue || detail.SuperficieCubierta.HasValue ||
         detail.Ambientes.HasValue || detail.Dormitorios.HasValue ||
         detail.Banos.HasValue || detail.Antiguedad.HasValue || detail.Cochera);

    private string FormatPrice()
    {
        if (detail is null) return "";
        var sym = detail.Moneda == "USD" ? "U$S" : "$";
        return $"{sym} {detail.Precio:N0}";
    }
}
