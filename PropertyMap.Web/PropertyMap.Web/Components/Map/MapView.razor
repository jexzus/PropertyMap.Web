@using PropertyMap.Core.DTOs
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="map-wrapper" id="map-wrapper">
    <div id="pm-map" style="width:100%;height:100%"></div>

    @if (popupListing is not null)
    {
        <div class="map-card-popup" role="dialog" aria-label="@popupListing.Titulo">
            <button class="map-popup-close" @onclick="ClosePopup" aria-label="Cerrar">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
            </button>

            @if (!string.IsNullOrEmpty(popupListing.FotoUrl))
            {
                <img class="map-popup-photo" src="@popupListing.FotoUrl" alt="@popupListing.Titulo" loading="lazy" />
            }

            <div class="map-popup-body">
                <div class="map-popup-price">@FormatPrice(popupListing)</div>
                <div class="map-popup-title">@popupListing.Titulo</div>
                <div class="map-popup-meta">@popupListing.TipoPropiedad · @popupListing.Operacion</div>
                <a class="map-popup-cta" href="/property/@popupListing.Id" target="_blank">
                    Ver detalle
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                </a>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public IEnumerable<ListingMapDto> Listings { get; set; } = [];
    [Parameter] public int? SelectedListingId { get; set; }
    [Parameter] public EventCallback<int> OnListingSelected { get; set; }

    private DotNetObjectReference<MapView>? dotNetRef;
    private ListingMapDto? popupListing;
    private bool mapInitialized;
    private IEnumerable<ListingMapDto> previousListings = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("mapInterop.initMap", "pm-map", -36.6200, -64.2895, 13);
            await JS.InvokeVoidAsync("mapInterop.centerOnUser");
            await JS.InvokeVoidAsync("mapInterop.initResize", "#listings-panel", "#resize-handle");
            mapInitialized = true;
            await UpdateMarkers();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!mapInitialized) return;

        if (!ReferenceEquals(Listings, previousListings))
        {
            previousListings = Listings;
            await UpdateMarkers();
        }

        if (SelectedListingId.HasValue)
            await JS.InvokeVoidAsync("mapInterop.selectMarker", SelectedListingId.Value);
    }

    private async Task UpdateMarkers()
    {
        if (!mapInitialized) return;
        await JS.InvokeVoidAsync("mapInterop.setMarkers", Listings, dotNetRef);
    }

    public async Task HighlightMarker(int? id)
    {
        if (!mapInitialized) return;
        await JS.InvokeVoidAsync("mapInterop.highlightMarker", id.HasValue ? (object)id.Value : null);
    }

    [JSInvokable]
    public async Task OnMarkerClick(List<int> ids)
    {
        var id = ids.FirstOrDefault();
        popupListing = Listings.FirstOrDefault(l => l.Id == id);
        await OnListingSelected.InvokeAsync(id);
        StateHasChanged();
    }

    private void ClosePopup() => popupListing = null;

    private static string FormatPrice(ListingMapDto l)
    {
        var sym = l.Moneda == "USD" ? "U$S" : "$";
        return $"{sym} {l.Precio:N0}";
    }

    public async ValueTask DisposeAsync()
    {
        dotNetRef?.Dispose();
        if (mapInitialized)
        {
            try { await JS.InvokeVoidAsync("mapInterop.clearMarkers"); }
            catch (JSDisconnectedException) { }
            catch (TaskCanceledException) { }
        }
    }
}
